rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // Users: read own, write only via Admin SDK (server)
    match /users/{uid} {
      allow read: if request.auth != null && request.auth.uid == uid;
      allow write: if false; // server-only
    }

    // Architectures: read own; writes only from server
    match /architectures/{id} {
      allow read: if request.auth != null && resource.data.uid == request.auth.uid;
      allow write: if false;
    }

    // Transactions: read own; writes only from server
    match /transactions/{id} {
      allow read: if request.auth != null && resource.data.uid == request.auth.uid;
      allow write: if false;
    }

    // Ledger entries: read own; writes only from server
    match /ledger/{id} {
      allow read: if request.auth != null && resource.data.uid == request.auth.uid;
      allow write: if false;
    }
  }
}
